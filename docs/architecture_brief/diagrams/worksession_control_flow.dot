digraph G {
  graph [rankdir=LR, bgcolor="white", margin=0.1, nodesep=0.38, ranksep=0.55];
  node [shape=box, style="rounded,filled", fontname="Inter", fontsize=10, color="#94a3b8", fillcolor="#f8fafc", fontcolor="#111827", margin="0.11,0.07"];
  edge [fontname="Inter", fontsize=8.5, color="#475569", fontcolor="#475569", arrowsize=0.65];

  intent [label="Human intent\nobjective + context", fillcolor="#eff6ff", color="#2563eb"];
  policy [label="Policy\nhuman-defined boundary", fillcolor="#fffbeb", color="#d97706"];
  action [label="AgentWorker action\nplanned or attempted", fillcolor="#eef2ff", color="#4f46e5"];
  decision [label="PolicyDecision\nallow · deny · narrow · review_required", fillcolor="#fff7ed", color="#ea580c"];
  event [label="JarvisEvent + Evidence\naccepted protocol state", fillcolor="#f0fdf4", color="#16a34a"];
  request [label="Request\nscoped blocker", fillcolor="#fef2f2", color="#dc2626"];
  review [label="Review\napprove · deny · narrow · correct · needs_revision", fillcolor="#eff6ff", color="#2563eb"];
  takeover [label="Takeover\nhuman controls affected scope", fillcolor="#eff6ff", color="#2563eb"];
  contribution [label="Contribution\nwho did what", fillcolor="#f0fdf4", color="#16a34a"];
  learning [label="Learning\nLearningRecord · MemoryProposal · SkillProposal", fillcolor="#ecfeff", color="#0891b2"];

  intent -> policy -> action -> decision;
  decision -> event [label="allow"];
  decision -> request [label="deny / review_required / blocked"];
  request -> review [label="human judgment"];
  request -> takeover [label="human control"];
  review -> action [label="resume when allowed"];
  takeover -> action [label="reconcile + resume"];
  event -> contribution -> learning;
}
