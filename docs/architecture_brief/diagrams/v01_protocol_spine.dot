digraph G {
  graph [rankdir=LR, bgcolor="white", margin=0.12, nodesep=0.42, ranksep=0.62];
  node [shape=box, style="rounded,filled", fontname="Inter", fontsize=10, color="#94a3b8", fillcolor="#f8fafc", fontcolor="#111827", margin="0.11,0.07"];
  edge [fontname="Inter", fontsize=8.5, color="#475569", fontcolor="#475569", arrowsize=0.65];

  workers [label="Workers + Actors\nWorker · Actor\nHumanWorker · AgentWorker", fillcolor="#eff6ff", color="#2563eb"];
  session [label="WorkSession Spine\nWorkSession · JarvisEvent\nobjective · status · revision · hash chain", fillcolor="#f0fdf4", color="#16a34a", penwidth=2];
  control [label="Control Plane\nPolicy · PolicyDecision\nRequest · Review · Takeover", fillcolor="#fff7ed", color="#ea580c"];
  proof [label="Proof + Attribution\nContribution\nEvidenceManifest", fillcolor="#ecfeff", color="#0891b2"];
  learning [label="Governed Learning\nLearningRecord\nMemoryProposal · SkillProposal", fillcolor="#f5f3ff", color="#7c3aed"];
  outcome [label="Post-Session Hook\nOutcomeReport", fillcolor="#fffbeb", color="#d97706"];

  workers -> session [label="start and act in"];
  session -> control [label="governed by"];
  control -> proof [label="records"];
  proof -> learning [label="teaches"];
  outcome -> learning [label="external feedback"];
  learning -> session [label="carries forward", constraint=false];
}
