digraph G {
  graph [rankdir=LR, bgcolor="white", margin=0.12, nodesep=0.38, ranksep=0.58];
  node [shape=box, style="rounded,filled", fontname="Inter", fontsize=10, color="#94a3b8", fillcolor="#f8fafc", fontcolor="#111827", margin="0.11,0.07"];
  edge [fontname="Inter", fontsize=8.5, color="#475569", fontcolor="#475569", arrowsize=0.65];

  export [label="Sealed WorkSession\nEvidenceManifest exported", fillcolor="#ecfeff", color="#0891b2"];
  external [label="External Outcome\naccepted · rejected · needs_revision\npartial · disputed", fillcolor="#ffffff"];
  learning [label="LearningRecord\ncreated through own operation\ngoverned post-session learning", fillcolor="#f5f3ff", color="#7c3aed"];
  outcome [label="OutcomeReport\nreferences learning_record_refs\nno sealed session mutation", fillcolor="#fffbeb", color="#d97706", penwidth=2];
  proposal [label="MemoryProposal / SkillProposal\ngoverned update", fillcolor="#f0fdf4", color="#16a34a"];
  boundary [label="Outside Jarvis\nscoring · payment · settlement · routing\nmarketplace logic", fillcolor="#fef2f2", color="#dc2626"];

  export -> external [label="evaluated by external system"];
  external -> learning [label="produces governed"];
  external -> outcome [label="reported through"];
  learning -> outcome [label="referenced by"];
  learning -> proposal [label="proposes governed update"];
  boundary -> outcome [style=dashed, label="does not enter core"];
}
