{
  "name": "@jarvis-protocol/sdk",
  "version": "0.1.0-alpha.0",
  "description": "TypeScript protocol helper package for Jarvis v0.1 records.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/",
    "fixtures/v0.1/",
    "README.md",
    "package.json"
  ],
  "jarvis": {
    "packageStatus": "Protocol Alpha helper tooling",
    "protocolVersion": "v0.1",
    "openapiVersion": "0.1.0",
    "fixtureSet": "v0.1"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./package.json": "./package.json",
    "./fixtures/v0.1/*": "./fixtures/v0.1/*"
  },
  "types": "./src/index.d.ts",
  "scripts": {
    "generate:openapi": "python3 ../../scripts/generate_typescript_openapi_surface.py",
    "check:boundary": "python3 ../../scripts/check_sdk_boundary.py",
    "test": "node --test tests/*.test.js"
  }
}
